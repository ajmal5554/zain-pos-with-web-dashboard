# Database
DATABASE_URL="file:../prisma/pos.db"

# JWT Secret (change this to a random string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# API Port
PORT=3001

# CORS Origin (dashboard URL)
CORS_ORIGIN="http://localhost:5173"

# Shared secret required for all /api/sync/* requests from the desktop app
CLOUD_SYNC_SECRET="replace-with-a-long-random-secret"
